NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server-only: required for TrueLayer token + OAuth state storage (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TrueLayer Data API (UK Open Banking) — https://console.truelayer.com
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
# Must match an allowlisted redirect URI in TrueLayer Console
TRUELAYER_REDIRECT_URI=http://localhost:3000/api/truelayer/callback

# Optional: sandbox (omit for production)
# TRUELAYER_AUTH_BASE=https://auth.truelayer-sandbox.com
# TRUELAYER_API_BASE=https://api.truelayer-sandbox.com/data/v1

# Optional: protect /api/cron/banking-sync (Vercel Cron sends Authorization: Bearer <CRON_SECRET> when set)
# CRON_SECRET=long-random-string
